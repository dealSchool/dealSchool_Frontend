rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Authentication and verification helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // admin@dealschool.in is bootstrapped securely as the primary system admin
    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == "admin@dealschool.in" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Dynamic Schema Validators ---

    function isValidApplication(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200 &&
             data.mobileNumber is string && data.mobileNumber.size() > 0 && data.mobileNumber.size() <= 50 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.linkedinUrl is string && data.linkedinUrl.size() > 0 && data.linkedinUrl.size() <= 600 &&
             data.city is string && data.city.size() > 0 && data.city.size() <= 200 &&
             data.currentStatus is string && (
               data.currentStatus == "Student" ||
               data.currentStatus == "Recent Graduate (0–2 years of experience)" ||
               data.currentStatus == "Working Professional" ||
               data.currentStatus == "Founder" ||
               data.currentStatus == "Freelancer" ||
               data.currentStatus == "Other"
             ) &&
             (!('collegeName' in data) || (data.collegeName is string && data.collegeName.size() <= 500)) &&
             (!('degree' in data) || (data.degree is string && data.degree.size() <= 500)) &&
             (!('graduationYear' in data) || (data.graduationYear is string && data.graduationYear.size() <= 100)) &&
             (!('currentRole' in data) || (data.currentRole is string && data.currentRole.size() <= 500)) &&
             (!('companyName' in data) || (data.companyName is string && data.companyName.size() <= 500)) &&
             (!('degreeEducationalBackground' in data) || (data.degreeEducationalBackground is string && data.degreeEducationalBackground.size() <= 500)) &&
             (!('yearsOfExperience' in data) || (data.yearsOfExperience is string && data.yearsOfExperience.size() <= 100)) &&
             (!('startupName' in data) || (data.startupName is string && data.startupName.size() <= 500)) &&
             (!('industrySector' in data) || (data.industrySector is string && data.industrySector.size() <= 500)) &&
             (!('startupLinkedinProfile' in data) || (data.startupLinkedinProfile is string && data.startupLinkedinProfile.size() <= 500)) &&
             (!('areaOfWork' in data) || (data.areaOfWork is string && data.areaOfWork.size() <= 500)) &&
             (!('freelancerLinkedinProfile' in data) || (data.freelancerLinkedinProfile is string && data.freelancerLinkedinProfile.size() <= 500)) &&
             (!('otherStatusSpecify' in data) || (data.otherStatusSpecify is string && data.otherStatusSpecify.size() <= 1000)) &&
             
             data.primaryReason is string && data.primaryReason.size() > 0 && data.primaryReason.size() <= 200 &&
             (!('primaryReasonOther' in data) || (data.primaryReasonOther is string && data.primaryReasonOther.size() <= 1000)) &&
             
             data.assessmentQ1 is string && data.assessmentQ1.size() > 0 && data.assessmentQ1.size() <= 20000 &&
             data.assessmentQ2 is string && data.assessmentQ2.size() > 0 && data.assessmentQ2.size() <= 20000 &&
             data.assessmentQ3 is string && (data.assessmentQ3 == 'Founder' || data.assessmentQ3 == 'Product' || data.assessmentQ3 == 'Market') &&
             
             (
                ('resumeLink' in data && data.resumeLink is string && data.resumeLink.size() > 0 && data.resumeLink.size() <= 2083) ||
                ('resumeUrl' in data && data.resumeUrl is string && data.resumeUrl.size() > 0 && data.resumeUrl.size() <= 2083)
              ) &&
             data.discoverySource is string && data.discoverySource.size() > 0 && data.discoverySource.size() <= 200 &&
             (!('discoverySourceOther' in data) || (data.discoverySourceOther is string && data.discoverySourceOther.size() <= 1000)) &&
             
             data.status is string && (
               data.status == 'pending' || 
               data.status == 'under_review' || 
               data.status == 'interview_invited' || 
               data.status == 'accepted' || 
               data.status == 'declined'
             );
    }

    function isValidContact(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 300 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 15000 &&
             data.status is string && (
               data.status == 'unread' || 
               data.status == 'read' || 
               data.status == 'archived'
             );
    }

    // --- Collection Rulesets ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /applications/{applicationId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      
      // Anyone can submit a fellowship application, with status forced to 'pending'
      allow create: if isValidId(applicationId) &&
                       isValidApplication(request.resource.data) &&
                       request.resource.data.status == "pending" &&
                       request.resource.data.createdAt == request.time &&
                       (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt == request.time);
                       
      // Admins can update statuses, ensuring immutable fields cannot be edited after initial creation
      allow update: if isAdmin() &&
                       isValidApplication(request.resource.data) &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.updatedAt == request.time &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
                       
      allow delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow get, list: if isAdmin();
      
      // Anyone can send an inquiry with status defaulting to 'unread'
      allow create: if isValidId(contactId) &&
                       isValidContact(request.resource.data) &&
                       request.resource.data.status == "unread" &&
                       request.resource.data.createdAt == request.time;
                       
      // Admins can moderate message logs (e.g. mark status as read or archived)
      allow update: if isAdmin() &&
                       isValidContact(request.resource.data) &&
                       request.resource.data.name == resource.data.name &&
                       request.resource.data.email == resource.data.email &&
                       request.resource.data.subject == resource.data.subject &&
                       request.resource.data.message == resource.data.message &&
                       request.resource.data.createdAt == resource.data.createdAt;
                       
      allow delete: if isAdmin();
    }
  }
}
